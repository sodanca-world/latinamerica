---
interface Props {
  facebook?: string;
  instagram?: string;
}

const { 
  facebook = "https://www.facebook.com/sodanca.americalatina", 
  instagram = "https://www.instagram.com/sodanca.latinamerica" 
} = Astro.props;

const youtube = "https://www.youtube.com/@sodancalatinamerica";
const sodancaLatina = "https://sodancalatina.com/sodanca";
---

<!-- Desktop: Redes sociais flutuantes fixas no canto inferior direito -->
<div class="hidden lg:flex fixed bottom-10 right-10 flex-col items-center gap-4 z-40">
  <div class="h-16 w-px bg-white/20"></div>
  
  <!-- Só Dança Latina Link -->
  <a 
    href={sodancaLatina} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="text-[10px] font-sans font-bold tracking-[0.2em] uppercase text-white/50 hover:text-white transition-colors [writing-mode:vertical-lr] rotate-180 mb-2"
  >
    sodancalatina.com
  </a>

  <!-- Instagram -->
  <a 
    href={instagram} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="rounded-full bg-white/5 border border-white/10 p-3 text-white/70 hover:bg-france-red hover:text-white hover:border-france-red/20 hover:-translate-y-1 transition-all duration-300 shadow-lg"
    aria-label="Instagram"
  >
    <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
    </svg>
  </a>

  <!-- Facebook -->
  <a 
    href={facebook} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="rounded-full bg-white/5 border border-white/10 p-3 text-white/70 hover:bg-france-blue hover:text-white hover:border-france-blue/20 hover:-translate-y-1 transition-all duration-300 shadow-lg"
    aria-label="Facebook"
  >
    <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
      <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z" />
    </svg>
  </a>

  <!-- YouTube -->
  <a 
    href={youtube} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="rounded-full bg-white/5 border border-white/10 p-3 text-white/70 hover:bg-red-600 hover:text-white hover:border-red-600/20 hover:-translate-y-1 transition-all duration-300 shadow-lg"
    aria-label="YouTube"
  >
    <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
      <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.507a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.87.507 9.388.507 9.388.507s7.518 0 9.388-.507a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
    </svg>
  </a>
</div>

<!-- Mobile: Redes sociais centralizadas no rodapé de cada página -->
<div class="flex lg:hidden items-center justify-center gap-4 py-8 border-t border-sodanca-nude/10 mt-12 bg-white/5 backdrop-blur-sm rounded-t-xl">
  <!-- Instagram -->
  <a 
    href={instagram} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="rounded-full bg-white/10 p-3 text-white hover:bg-france-red transition-colors"
    aria-label="Instagram"
  >
    <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
    </svg>
  </a>

  <!-- Facebook -->
  <a 
    href={facebook} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="rounded-full bg-white/10 p-3 text-white hover:bg-france-blue transition-colors"
    aria-label="Facebook"
  >
    <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
      <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z" />
    </svg>
  </a>

  <!-- YouTube -->
  <a 
    href={youtube} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="rounded-full bg-white/10 p-3 text-white hover:bg-red-600 transition-colors"
    aria-label="YouTube"
  >
    <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
      <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.507a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.87.507 9.388.507 9.388.507s7.518 0 9.388-.507a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
    </svg>
  </a>
  
  <!-- Só Dança Latina link text -->
  <span class="text-white/40 text-xs font-semibold px-2">|</span>
  <a 
    href={sodancaLatina} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="text-xs font-semibold uppercase tracking-wider text-white/60 hover:text-white transition-colors"
  >
    sodancalatina.com
  </a>
</div>
