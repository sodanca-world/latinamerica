---
interface Props {
  loja: {
    Nome: string;
    Cidade?: string;
    Slug: string;
    Endereco?: string;
    LinkMaps?: string;
    Telefone?: string;
    Email?: string;
    Instagram?: string;
    Facebook?: string;
    Website?: string;
    Logo?: Array<{ url: string }>;
  };
  isDetail?: boolean;
}

const { loja, isDetail = false } = Astro.props;

const logoUrl = (loja.Logo && loja.Logo.length > 0) 
  ? loja.Logo[0].url 
  : '/assets/images/cropped-Logo-2.png'; // Fallback elegante do logo Só Dança

// Iniciais para o avatar caso não tenha logotipo real
const initials = loja.Nome.split(' ')
  .map(n => n[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

{isDetail ? (
  /* ================= ESTADO FIXO ABERTO (Para página de detalhes) ================= */
  <div class="w-full bg-[#2d3238]/90 backdrop-blur-md border border-white/10 rounded-2xl p-6 md:p-8 text-white shadow-lg flex flex-col justify-between">
    <div>
      <div class="flex items-start justify-between gap-4 mb-6">
        <div class="h-16 w-16 shrink-0 overflow-hidden rounded-xl border border-white/10 bg-white p-1 flex items-center justify-center">
          {loja.Logo && loja.Logo.length > 0 ? (
            <img 
              src={logoUrl} 
              alt={loja.Nome} 
              class="h-full w-full object-contain"
              loading="lazy"
            />
          ) : (
            <span class="font-sans text-lg font-bold text-sodanca-dark">{initials}</span>
          )}
        </div>
      </div>

      <h3 class="font-sans text-xl font-bold">
        {loja.Nome}
      </h3>
      {loja.Cidade && (
        <span class="text-xs font-semibold text-white/50 uppercase tracking-widest block mb-4 mt-0.5">
          {loja.Cidade}
        </span>
      )}

      <div class="space-y-4 text-sm text-white/80 mb-8">
        {loja.Endereco && (
          <div class="flex items-start gap-3">
            <svg class="h-5 w-5 text-sodanca-nude shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {loja.LinkMaps ? (
              <a 
                href={loja.LinkMaps} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="hover:text-sodanca-nude hover:underline transition-colors leading-relaxed"
              >
                {loja.Endereco}
              </a>
            ) : (
              <span class="leading-relaxed">{loja.Endereco}</span>
            )}
          </div>
        )}

        {loja.Telefone && (
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-sodanca-nude shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${loja.Telefone.replace(/\s+/g, '')}`} class="hover:text-sodanca-nude transition-colors font-medium">
              {loja.Telefone}
            </a>
          </div>
        )}

        {loja.Email && (
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-sodanca-nude shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${loja.Email}`} class="hover:text-sodanca-nude transition-colors break-all">
              {loja.Email}
            </a>
          </div>
        )}

        {loja.Instagram && (
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-sodanca-nude shrink-0 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            <a href={loja.Instagram} target="_blank" rel="noopener noreferrer" class="hover:text-sodanca-nude hover:underline transition-colors">
              Instagram
            </a>
          </div>
        )}

        {loja.Facebook && (
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-sodanca-nude shrink-0 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
            <a href={loja.Facebook} target="_blank" rel="noopener noreferrer" class="hover:text-sodanca-nude hover:underline transition-colors">
              Facebook
            </a>
          </div>
        )}
      </div>
    </div>

    <div class="border-t border-white/10 pt-5 flex items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span></span>
      </div>

      {loja.Website && (
        <a 
          href={loja.Website} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="rounded border border-white text-white hover:bg-white hover:text-sodanca-dark px-5 py-2 text-xs font-semibold uppercase tracking-wider transition-colors duration-200"
        >
          Website
        </a>
      )}
    </div>
  </div>
) : (
  /* ================= ESTADO FLIP CARD 3D (Para listagem por cidade) ================= */
  <div class="w-full h-[400px] perspective group select-none">
    <div class="relative w-full h-full duration-700 transform-style-3d group-hover:rotate-y-180 cursor-pointer">
      
      <!-- FRENTE: Nome + Imagem de Fundo/Logo + Ícone de Rotação -->
      <div class="absolute inset-0 backface-hidden bg-[#2d3238]/90 backdrop-blur-md border border-white/10 rounded-2xl p-6 flex flex-col justify-between items-center text-center shadow-lg">
        
        <!-- Header da Loja (Nome + Cidade) -->
        <div class="shrink-0 w-full">
          <h3 class="font-sans text-xl font-bold text-white tracking-wide uppercase">
            {loja.Nome}
          </h3>
          {loja.Cidade && (
            <span class="text-sm font-semibold text-white/60 uppercase tracking-widest block mt-0.5">
              {loja.Cidade}
            </span>
          )}
        </div>

        <!-- Logo / Store Image Container -->
        <div class="w-full h-48 overflow-hidden rounded-xl border border-white/10 bg-white flex items-center justify-center p-1.5 my-2">
          <img 
            src={logoUrl} 
            alt={loja.Nome} 
            class="h-full w-full object-contain"
            loading="lazy"
          />
        </div>

        <!-- Flip Icon (Estilo Retweet do FontAwesome) -->
        <div class="shrink-0 pt-2 text-white/40 group-hover:text-white/80 transition-colors">
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
            <path d="M19 8l-4 4h3c0 3.31-2.69 6-6 6-1.01 0-1.97-.25-2.8-.7l-1.46 1.46C8.97 19.54 10.43 20 12 20c4.42 0 8-3.58 8-8h3l-4-4zM6 12c0-3.31 2.69-6 6-6 1.01 0 1.97.25 2.8.7l1.46-1.46C15.03 4.46 13.57 4 12 4c-4.42 0-8 3.58-8 8H1l4 4 4-4H6z"/>
          </svg>
        </div>
      </div>

      <!-- VERSO: Detalhes de Contato completos -->
      <div class="absolute inset-0 backface-hidden rotate-y-180 bg-[#2d3238]/95 border border-white/10 rounded-2xl p-6 flex flex-col justify-between shadow-lg text-white">
        <div>
          <!-- Title on back -->
          <div class="mb-5 text-center border-b border-white/10 pb-3">
            <h3 class="font-sans text-xl font-bold tracking-wide uppercase text-white">
              {loja.Nome}
            </h3>
            {loja.Cidade && (
              <span class="text-sm font-semibold text-white/60 uppercase tracking-widest block mt-0.5">
                {loja.Cidade}
              </span>
            )}
          </div>

          <!-- Contacts (Alinhamento à esquerda, lista vertical idêntica ao original) -->
          <div class="space-y-3.5 text-[13px] md:text-sm text-white/90">
            {loja.Endereco && (
              <div class="flex items-start gap-3">
                <svg class="h-[18px] w-[18px] text-sodanca-nude shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {loja.LinkMaps ? (
                  <a 
                    href={loja.LinkMaps} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="hover:text-sodanca-nude hover:underline transition-colors leading-relaxed"
                  >
                    {loja.Endereco}
                  </a>
                ) : (
                  <span class="leading-relaxed">{loja.Endereco}</span>
                )}
              </div>
            )}

            {loja.Telefone && (
              <div class="flex items-center gap-3">
                <svg class="h-[18px] w-[18px] text-sodanca-nude shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <a href={`tel:${loja.Telefone.replace(/\s+/g, '')}`} class="hover:text-sodanca-nude transition-colors">
                  {loja.Telefone}
                </a>
              </div>
            )}

            {loja.Email && (
              <div class="flex items-center gap-3">
                <svg class="h-[18px] w-[18px] text-sodanca-nude shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href={`mailto:${loja.Email}`} class="hover:text-sodanca-nude transition-colors break-all">
                  {loja.Email}
                </a>
              </div>
            )}

            {loja.Instagram && (
              <div class="flex items-center gap-3">
                <svg class="h-[18px] w-[18px] text-sodanca-nude shrink-0 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
                <a href={loja.Instagram} target="_blank" rel="noopener noreferrer" class="hover:text-sodanca-nude hover:underline transition-colors">
                  Instagram
                </a>
              </div>
            )}

            {loja.Facebook && (
              <div class="flex items-center gap-3">
                <svg class="h-[18px] w-[18px] text-sodanca-nude shrink-0 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
                <a href={loja.Facebook} target="_blank" rel="noopener noreferrer" class="hover:text-sodanca-nude hover:underline transition-colors">
                  Facebook
                </a>
              </div>
            )}
          </div>
        </div>

        {/* Website Button */}
        <div class="pt-4 border-t border-white/10 shrink-0">
          {loja.Website ? (
            <a 
              href={loja.Website} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="block w-full text-center py-2 rounded border border-white text-white hover:bg-white hover:text-sodanca-dark text-sm font-bold uppercase tracking-wider transition-colors duration-200"
            >
              Website
            </a>
          ) : (
            <span class="block w-full text-center py-2 text-white/30 text-sm font-bold uppercase tracking-wider">
              Sem website
            </span>
          )}
        </div>
      </div>

    </div>
  </div>
)}
