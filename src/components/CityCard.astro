---
interface Props {
  nome: string;
  slug: string;
  lojasCount: number;
}

const { nome, slug, lojasCount } = Astro.props;
---

<a 
  href={`/ville/${slug}/`}
  class="group relative flex flex-col justify-between overflow-hidden rounded-2xl border border-sodanca-nude/20 bg-white p-6 card-hover-effect"
>
  <div class="flex flex-col gap-1">
    <h3 class="font-sans text-lg font-semibold text-sodanca-dark group-hover:text-france-blue transition-colors">
      {nome}
    </h3>
    <p class="text-xs text-gray-400 font-medium">
      {lojasCount} {lojasCount === 1 ? 'boutique partenaire' : 'boutiques partenaires'}
    </p>
  </div>
  
  <div class="mt-8 flex items-center justify-between text-xs font-semibold uppercase tracking-wider text-france-blue">
    <span>Découvrir</span>
    <svg class="h-4 w-4 transform transition-transform group-hover:translate-x-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
